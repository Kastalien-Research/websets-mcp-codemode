{
  "name": "company-watchtower",
  "proxy": "{{subject}} is preparing a major strategic move",
  "lenses": [
    {
      "id": "hiring-signals",
      "source": {
        "query": "{{subject}} hiring VP director head of engineering product",
        "entity": { "type": "company" },
        "criteria": [
          { "description": "Job posting is for a leadership or senior technical role" },
          { "description": "Posted within the last 60 days" }
        ],
        "enrichments": [
          { "description": "Number of similar leadership roles currently open at this company", "format": "number" },
          { "description": "Department or function being hired for", "format": "text" },
          { "description": "Seniority level", "format": "options", "options": [{ "label": "Director" }, { "label": "VP" }, { "label": "C-suite" }, { "label": "Head of" }, { "label": "Senior IC" }] }
        ],
        "count": 40
      }
    },
    {
      "id": "press-activity",
      "source": {
        "query": "{{subject}} announcement launch partnership acquisition",
        "entity": { "type": "company" },
        "criteria": [
          { "description": "News article or press release about a specific company action, not general industry coverage" },
          { "description": "Published within the last 45 days" }
        ],
        "enrichments": [
          { "description": "Type of announcement", "format": "options", "options": [{ "label": "Product launch" }, { "label": "Partnership" }, { "label": "Acquisition" }, { "label": "Funding" }, { "label": "Expansion" }, { "label": "Other" }] },
          { "description": "Publication tier", "format": "options", "options": [{ "label": "Tier 1 (TechCrunch, Bloomberg, WSJ)" }, { "label": "Tier 2 (industry press)" }, { "label": "Tier 3 (blog, press release)" }] }
        ],
        "count": 40
      }
    },
    {
      "id": "ip-filings",
      "source": {
        "query": "{{subject}} patent filed trademark application intellectual property",
        "entity": { "type": "company" },
        "criteria": [
          { "description": "References a specific patent filing, trademark application, or IP registration" }
        ],
        "enrichments": [
          { "description": "Type of IP filing", "format": "options", "options": [{ "label": "Patent" }, { "label": "Trademark" }, { "label": "Trade secret disclosure" }, { "label": "Other" }] },
          { "description": "Technology or product area the filing relates to", "format": "text" }
        ],
        "count": 30
      }
    }
  ],
  "shapes": [
    {
      "lensId": "hiring-signals",
      "conditions": [
        { "enrichment": "Number of similar leadership roles currently open at this company", "operator": "gte", "value": 3 },
        { "enrichment": "Seniority level", "operator": "oneOf", "value": ["Director", "VP", "C-suite", "Head of"] }
      ],
      "logic": "all"
    },
    {
      "lensId": "press-activity",
      "conditions": [
        { "enrichment": "Type of announcement", "operator": "oneOf", "value": ["Product launch", "Partnership", "Acquisition", "Funding"] }
      ],
      "logic": "all"
    },
    {
      "lensId": "ip-filings",
      "conditions": [
        { "enrichment": "Technology or product area the filing relates to", "operator": "exists" }
      ],
      "logic": "all"
    }
  ],
  "join": {
    "by": "entity+temporal",
    "entityMatch": { "method": "url+name", "nameThreshold": 0.85 },
    "temporal": { "window": "within_days", "days": 90 },
    "minLensOverlap": 2
  },
  "signal": {
    "proxy": "Company is preparing a major strategic move — simultaneous leadership hiring, public announcements, and IP activity",
    "requires": {
      "type": "combination",
      "sufficient": [
        ["hiring-signals", "press-activity"],
        ["hiring-signals", "ip-filings"],
        ["press-activity", "ip-filings"]
      ]
    }
  },
  "monitor": { "cron": "0 9 * * 1", "timezone": "America/New_York" },
  "webhookUrl": "http://localhost:7860",
  "_usage": {
    "description": "Watches a company for coordinated signals of major strategic activity. Any two of three lenses finding the same company triggers the signal.",
    "example_variables": {
      "subject": "Tesla"
    }
  }
}
